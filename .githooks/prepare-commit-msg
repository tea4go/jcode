#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:-}"
if [[ -z "$MSG_FILE" || ! -f "$MSG_FILE" ]]; then
  exit 0
fi

if [[ "${JCODE_COMMIT_AI:-1}" == "0" ]]; then
  exit 0
fi

if ! command -v git >/dev/null 2>&1; then
  exit 0
fi

if ! command -v jcode >/dev/null 2>&1; then
  exit 0
fi

raw_msg="$(cat "$MSG_FILE" 2>/dev/null || true)"
raw_msg="${raw_msg//$'\r'/}"
raw_msg="$(printf "%s" "$raw_msg" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"

if [[ ! "$raw_msg" =~ ^fix:\ \([0-9]{4}-[0-9]{2}-[0-9]{2}\ [0-9]{2}:[0-9]{2}:[0-9]{2}\)$ ]]; then
  exit 0
fi

if [[ -z "$(git diff --cached --name-only 2>/dev/null || true)" ]]; then
  exit 0
fi

names="$(git diff --cached --name-status --no-renames 2>/dev/null | head -n 200 || true)"
diff="$(git diff --cached --no-color 2>/dev/null | head -c 15000 || true)"

prompt=$'你是一个资深软件工程师。请根据下面的 Git staged 变更，生成一个 Conventional Commits 风格的提交信息（中文）。\n要求：\n1) 第一行是 subject，格式：<type>(<scope>): <一句话> 或 <type>: <一句话>，subject 不超过 72 字符。\n2) 如有必要，可在空行后给出 2-6 行 body，每行简短说明关键点。\n3) 只输出提交信息本身，不要解释，不要代码块，不要前后缀。\n4) type 只能用：feat|fix|refactor|docs|style|test|chore\n5) 如果主要是日志/脚本/构建相关，优先用 chore 或 refactor。\n\n以下是文件列表（name-status）：\n'
prompt+="${names}"
prompt+=$'\n\n以下是 diff（可能截断）：\n'
prompt+="${diff}"

output="$(
  JCODE_NON_INTERACTIVE=1 \
  JCODE_RUN_AUTO_POKE=0 \
  jcode --quiet run "$prompt" 2>/dev/null || true
)"
output="${output//$'\r'/}"
output="$(printf "%s" "$output" | sed -e 's/[[:space:]]*$//' -e '/^[[:space:]]*$/{$d;}')"

if [[ -n "$(printf "%s" "$output" | tr -d '[:space:]')" ]]; then
  printf "%s\n" "$output" > "$MSG_FILE"
fi
